rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Jobs - leitura pública, escrita só do backend (service account)
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if false; // só service account (backend)
    }

    // Chat history - leitura pública, escrita só do backend
    match /chat_history/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Stats - leitura pública
    match /stats/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
